# =============================================================================
# mnemos — Variables de Entorno
# =============================================================================
# Copia este archivo a `.env` y llená los valores.
# Local: solo necesitás Supabase + OpenRouter. SearxNG corre con docker compose.
# Producción: estos mismos valores se cargan a GCP Secret Manager con gcp-setup.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Frontend (publishable key, segura para exponer en cliente)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# -----------------------------------------------------------------------------
# Supabase — Backend (secret key, NUNCA exponer al cliente)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# -----------------------------------------------------------------------------
# Embeddings + LLM via OpenRouter (https://openrouter.ai/keys)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...

# -----------------------------------------------------------------------------
# SearxNG (búsqueda web anónima)
# -----------------------------------------------------------------------------
SEARXNG_URL=http://localhost:8080
SEARXNG_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# MCP — Configuración para .vscode/mcp.json (GitHub Copilot Agent Mode)
# -----------------------------------------------------------------------------
# Solo se necesitan si vas a usar Copilot con los 3 MCPs (supabase, gcp, mnemos).
# Para correr backend/frontend sin Copilot, podés dejarlos vacíos.

# Token personal de Supabase (NO es la secret key del proyecto):
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# Project ref = subdominio de tu URL de Supabase (ej: abcd1234efgh5678)
SUPABASE_PROJECT_REF=your-project-ref

# Project ID de GCP (Console GCP → Settings)
GCP_PROJECT_ID=your-gcp-project-id
